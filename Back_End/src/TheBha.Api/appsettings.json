{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Cookie": {
      "SameSite": "Lax"
    },
    "RateLimiting": {
      "RegisterPermitLimit": 5,
      "LoginPermitLimit": 10,
      "WindowSeconds": 60
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "DataProtection": {
    "KeysPath": ""
  }
}
